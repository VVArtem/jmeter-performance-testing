          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223: Prepare Dynamic Cart Prices" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">//productPrice=PRODUCT_PRICES_NOT_FOUND
//productPrice_1=product_price_118__236.00
//productPrice_1_g=2
//productPrice_1_g0=product_price_118__&quot; value=&quot;236.00&quot;
//productPrice_1_g1=product_price_118__
//productPrice_1_g2=236.00
//productPrice_2=product_price_89__345.00
//productPrice_2_g=2
//productPrice_2_g0=product_price_89__&quot; value=&quot;345.00&quot;
//productPrice_2_g1=product_price_89__
//productPrice_2_g2=345.00
//productPrice_matchNr=2

def countString = vars.get(&quot;productPrice_matchNr&quot;)

int count = countString.toInteger()

for (int i = 1; i &lt;= count; i++) {
        
    def productId = vars.get(&quot;productPrice_&quot; + i + &quot;_g1&quot;)
    def productPrice = vars.get(&quot;productPrice_&quot; + i + &quot;_g2&quot;)
        
    sampler.addArgument(productId, productPrice) 
}
</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>
