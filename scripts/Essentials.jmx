          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223: Prepare Dynamic Cart Quantity">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

def jsonString = vars.get(&quot;cartContent&quot;)

def map = new JsonSlurper().parseText(jsonString)

map.each { id, quantity -&gt;

    sampler.addArgument(&quot;p_id[]&quot;, id) 
    sampler.addArgument(&quot;p_quantity[]&quot;, quantity.toString()) 

}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PreProcessor>
